{
  "expo": {
    "name": "Paku",
    "slug": "paku-vet",
    "version": "1.0.0",
    "scheme": "paku",
    "orientation": "portrait",
    "icon": "./assets/app/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/app/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "usesCleartextTraffic": true,
      "permissions": ["INTERNET", "CAMERA", "RECORD_AUDIO"],
      "package": "com.aldoparradev.pakuvet",
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCP8NhD7R-g5J81DR-_ZUr_WWx7OpQasaA"
        }
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aldoparradev.pakuvet",
      "icon": "./assets/app/icon.png"
    },
    "web": {
      "favicon": "./assets/app/favicon.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que $(PRODUCT_NAME) use tu ubicación."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/app/splash.png",
          "imageWidth": 900,
          "resizeMode": "contain"
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Paku necesita acceso a la cámara para el servicio en vivo",
          "microphonePermission": "Paku necesita acceso al micrófono para el servicio en vivo"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6a71eecb-b961-400b-a9e8-d62cb86256f1"
      }
    }
  }
}
