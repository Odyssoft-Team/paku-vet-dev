{
  "expo": {
    "name": "Paku",
    "slug": "paku-vet",
    "version": "1.0.0",
    "scheme": "paku",
    "orientation": "portrait",
    "icon": "./assets/app/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/app/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "usesCleartextTraffic": true,
      "permissions": [
        "INTERNET",
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "package": "com.aldoparradev.pakuvet",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCP8NhD7R-g5J81DR-_ZUr_WWx7OpQasaA"
        }
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aldoparradev.pakuvet",
      "icon": "./assets/app/icon.png",
      "bitcode": false
    },
    "web": {
      "favicon": "./assets/app/favicon.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que $(PRODUCT_NAME) use tu ubicación."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/app/splash.png",
          "imageWidth": 900,
          "resizeMode": "contain"
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Paku necesita acceso a la cámara para el servicio en vivo",
          "microphonePermission": "Paku necesita acceso al micrófono para el servicio en vivo"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "14e3627f-3494-4f16-abd2-f9eeac2ab59a"
      }
    },
    "owner": "prodevelop123"
  }
}
